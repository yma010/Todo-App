# Copy to .env and fill in. Never commit .env.

# "dev" or "prod". In "prod", the app refuses to start unless COOKIE_SECURE=true
# and FRONTEND_ORIGIN starts with https://.
ENV=dev

# Postgres connection used by both the app and Alembic.
DATABASE_URL=postgresql+psycopg://todo:todo@localhost:5432/todo

# Origins allowed to make mutating requests (POST/PATCH/DELETE). Comma-
# separated. localhost and 127.0.0.1 are both listed because browsers
# don't canonicalize them — Vite advertises both, and either URL must
# work. In prod, set this to the single https origin of the SPA.
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Session config.
SESSION_COOKIE_NAME=todo_session
SESSION_EXPIRES_DAYS=14
COOKIE_SECURE=false   # set to true in production (HTTPS only)

# Reminder lead time before due_at, in seconds. 900 = 15 minutes.
REMINDER_LEAD_SECONDS=900

# Misfire grace time for APScheduler jobs whose fire time passed during downtime.
SCHEDULER_MISFIRE_GRACE_SECONDS=3600

# Per-IP auth throttle (in-process limiter; single worker only).
AUTH_LOGIN_MAX_PER_MIN=10
AUTH_REGISTER_MAX_PER_10MIN=5
