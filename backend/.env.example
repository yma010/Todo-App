# Copy to .env and fill in. Never commit .env.

# Postgres connection used by both the app and Alembic.
DATABASE_URL=postgresql+psycopg://todo:todo@localhost:5432/todo

# Where the frontend dev server runs. Used for CORS allow-origin.
FRONTEND_ORIGIN=http://localhost:5173

# Session config.
SESSION_COOKIE_NAME=todo_session
SESSION_EXPIRES_DAYS=14
COOKIE_SECURE=false   # set to true in production (HTTPS only)

# Reminder lead time before due_at, in seconds. 900 = 15 minutes.
REMINDER_LEAD_SECONDS=900

# Misfire grace time for APScheduler jobs whose fire time passed during downtime.
SCHEDULER_MISFIRE_GRACE_SECONDS=3600
